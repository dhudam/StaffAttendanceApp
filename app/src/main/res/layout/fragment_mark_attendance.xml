<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView android:text="Mark Attendance"
            android:textSize="22sp" android:textStyle="bold"
            android:textColor="@color/text_primary" android:layout_marginBottom="16dp"/>

        <!-- Employee Selector -->
        <TextView android:text="Select Employee" android:textColor="@color/text_secondary" android:textSize="12sp"/>
        <Spinner android:id="@+id/spinnerEmployee"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_spinner"
            android:layout_marginBottom="16dp" android:padding="12dp"/>

        <!-- Status card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            app:cardCornerRadius="12dp" app:cardBackgroundColor="@color/surface_dark"
            android:layout_marginBottom="20dp">
            <TextView android:id="@+id/tvStatus"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Not checked in yet" android:padding="16dp"
                android:textColor="@color/text_secondary" android:textSize="14sp"
                android:gravity="center"/>
        </androidx.cardview.widget.CardView>

        <!-- Check-in / Check-out buttons -->
        <Button android:id="@+id/btnCheckIn"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:text="Check In" android:textSize="16sp"
            android:backgroundTint="@color/primary"
            android:layout_marginBottom="12dp"/>

        <Button android:id="@+id/btnCheckOut"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:text="Check Out" android:textSize="16sp"
            android:backgroundTint="@color/card_orange"
            android:enabled="false"/>

        <!-- Camera capture group (initially hidden) -->
        <LinearLayout android:id="@+id/cameraGroup"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:visibility="gone"
            android:layout_marginTop="16dp">

            <TextView android:text="Take a selfie to verify identity"
                android:textColor="@color/text_secondary" android:textSize="12sp"
                android:gravity="center" android:layout_marginBottom="8dp"/>

            <androidx.camera.view.PreviewView
                android:id="@+id/previewView"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_marginBottom="12dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <Button android:id="@+id/btnCancelCamera"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Cancel"
                    android:backgroundTint="#555555" android:layout_marginEnd="8dp"/>
                <Button android:id="@+id/btnCapture"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Capture"
                    android:backgroundTint="@color/primary"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
